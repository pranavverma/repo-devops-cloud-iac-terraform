# Terraform state — never commit state files
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform/
.terraform.lock.hcl

# Variable files with real values — commit only .example versions
*.tfvars
!*.tfvars.example

# Crash logs
crash.log
crash.*.log

# Override files (local machine-specific)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Sensitive files
*.pem
*.key

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db
